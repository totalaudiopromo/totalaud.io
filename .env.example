# TotalAud.io Environment Variables

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# GOOGLE OAUTH (Gmail + Sheets Integrations)
# ============================================
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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45

# ============================================
# APPLICATION
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production URL (for OAuth redirects)
# NEXT_PUBLIC_APP_URL=https://totalaud.io

# ============================================
# SPOTIFY API (Phase 14.3: Artist Intelligence)
# ============================================
# Get credentials at: https://developer.spotify.com/dashboard
# Required for Operator Scene artist detection
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# ============================================
# AI PROVIDER (Optional)
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# ============================================
# TOTAL AUDIO PLATFORM (TAP) API
# ============================================
# Service-specific API keys for Intel, Pitch, and Tracker
# Get keys from: command.totalaudiopromo.com
TAP_API_KEY_INTEL=tap_live_xxx
TAP_API_KEY_PITCH=tap_live_xxx
TAP_API_KEY_TRACKER=tap_live_xxx

# Optional: Custom URLs (defaults to production)
# TAP_INTEL_URL=https://intel.totalaudiopromo.com
# TAP_PITCH_URL=https://pitch.totalaudiopromo.com
# TAP_TRACKER_URL=https://tracker.totalaudiopromo.com

# ============================================
# SENTRY (Error Tracking)
# ============================================
# Create a project at https://sentry.io and grab the DSN
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx
# Required for source map uploads (optional for local dev)
# SENTRY_ORG=your-org
# SENTRY_PROJECT=totalaud-io
# SENTRY_AUTH_TOKEN=sntrys_xxx

# ============================================
# STRIPE (Billing)
# ============================================
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Starter (GBP5/month)
STRIPE_PRICE_STARTER_GBP=price_xxx
STRIPE_PRICE_STARTER_USD=price_xxx
STRIPE_PRICE_STARTER_EUR=price_xxx

# Pro (GBP19/month)
STRIPE_PRICE_PRO_GBP=price_xxx
STRIPE_PRICE_PRO_USD=price_xxx
STRIPE_PRICE_PRO_EUR=price_xxx

# Pro Annual (GBP149/year)
STRIPE_PRICE_PRO_ANNUAL_GBP=price_xxx
STRIPE_PRICE_PRO_ANNUAL_USD=price_xxx
STRIPE_PRICE_PRO_ANNUAL_EUR=price_xxx

# Power (GBP79/month) -- NEEDS PRICE IDS FROM STRIPE DASHBOARD
STRIPE_PRICE_POWER_GBP=price_xxx
STRIPE_PRICE_POWER_USD=price_xxx
STRIPE_PRICE_POWER_EUR=price_xxx

# Power Annual (GBP758/year) -- NEEDS PRICE IDS FROM STRIPE DASHBOARD
STRIPE_PRICE_POWER_ANNUAL_GBP=price_xxx
STRIPE_PRICE_POWER_ANNUAL_USD=price_xxx
STRIPE_PRICE_POWER_ANNUAL_EUR=price_xxx

# ============================================
# FEATURE FLAGS (Optional)
# ============================================
NEXT_PUBLIC_ENABLE_INTEGRATIONS=true
NEXT_PUBLIC_ENABLE_SOUND_CUES=true
NEXT_PUBLIC_ENABLE_REALTIME=true

# ============================================
# NOTES
# ============================================
# 1. Gmail + Sheets can share the same OAuth client ID if both APIs are enabled
# 2. Redirect URIs must be configured in Google Cloud Console:
#    - http://localhost:3000/api/oauth/google/callback (development)
#    - https://totalaud.io/api/oauth/google/callback (production)
# 3. Required scopes:
#    - Gmail: https://www.googleapis.com/auth/gmail.readonly
#    - Gmail: https://www.googleapis.com/auth/gmail.metadata
#    - Sheets: https://www.googleapis.com/auth/spreadsheets.readonly
# 4. Spotify API uses Client Credentials flow (no redirect URI needed)
#    - Create app at: https://developer.spotify.com/dashboard
#    - Enable "Web API" permissions
#    - No redirect URI required for artist search (server-side only)
